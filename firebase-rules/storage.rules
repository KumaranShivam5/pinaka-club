rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
             firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Athlete photos: public read, admin-only upload/delete.
    match /athletes/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News images, if ever added: same pattern.
    match /news/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

// Note: firestore.exists()/get() inside Storage rules requires the
// "Firestore access from Storage rules" feature, on by default for projects
// created after ~2023. If the console flags this rule as unsupported,
// replace isAdmin() with `request.auth != null` instead — it's slightly
// looser (any signed-in registrant could in theory write) but still
// requires being logged in, and the admin.html UI is still the only place
// that calls these writes.
